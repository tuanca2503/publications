      "id": "serde-json",
      "label": "serde / JSON",
      "type": "impl",
      "projects": [
        "agent",
        "cli-tool"
      ],
      "metadata": {
        "description": "Rust's serde framework — serialize/deserialize tự động qua derive macro, zero-copy khi có thể",
