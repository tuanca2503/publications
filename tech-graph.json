    },
    {
      "id": "async-await",
      "label": "Async / Await",
      "type": "impl",
      "projects": [
        "agent",
        "api-server"
      ],
      "metadata": {
        "description": "Non-blocking I/O với coroutines. Hiệu quả cho I/O-bound tasks như gọi API, đọc file",
        "pros": [
          "Không block thread",
          "Dễ đọc hơn callbacks",
          "Low overhead"
        ],
        "cons": [
          "Không phù hợp CPU-bound tasks"
        ]
      }
    },
    {
      "id": "multithreading",
      "label": "Multithreading",
      "type": "impl",
      "projects": [
        "agent",
        "data-pipeline"
      ],
      "metadata": {
        "description": "Chạy nhiều thread OS song song. Phù hợp CPU-bound tasks như xử lý data lớn",
        "pros": [
          "Tận dụng multi-core",
          "Phù hợp CPU-bound"
        ],
        "cons": [
          "Race conditions",
          "Deadlock risk",
          "Memory overhead"
        ]
      }
    },
