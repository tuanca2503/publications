      "type": "impl",
      "projects": [
        "agent",
        "rag-pipeline",
        "web-app"
      ],
      "metadata": {
        "description": "Lưu memory vào relational database. Bền vững, có thể query phức tạp",
        "storage": "disk",
        "pros": [
          "Bền vững qua restart",
          "Query linh hoạt",
          "ACID transactions"
        ],
        "cons": [
          "Latency cao hơn RAM",
          "Schema cứng"
        ]
      }
    },
    {
