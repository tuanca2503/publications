      "type": "technique",
      "projects": [
        "agent",
        "cli-tool",
        "api-server",
        "rag-pipeline"
      ],
      "metadata": {
        "description": "Chiến lược xử lý lỗi gracefully, đảm bảo hệ thống không crash và recover được"
      }
    },
    {
      "id": "result-type",
      "label": "Result / Option",
      "type": "impl",
      "projects": [
        "agent",
        "cli-tool"
      ],
      "metadata": {
        "description": "Rust's Result<T,E> và Option<T> — encode lỗi vào type system, buộc xử lý explicit",
        "pros": [
          "Compile-time safety",
          "Không có null pointer",
          "Rõ ràng flow control"
        ],
        "cons": [
          "Verbose hơn try/catch"
        ]
      }
    },
    {
      "id": "retry-backoff",
      "label": "Retry / Backoff",
      "type": "impl",
      "projects": [
        "agent",
        "rag-pipeline",
        "api-server"
      ],
      "metadata": {
        "description": "Tự động retry khi gặp lỗi tạm thời, với exponential backoff để tránh overload",
        "pros": [
          "Resilient với network errors",
          "Tự phục hồi"
        ],
        "cons": [
          "Tăng latency khi lỗi",
          "Cần giới hạn retry"
        ]
      }
    },
