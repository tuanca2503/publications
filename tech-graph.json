    {
      "id": "singleton-ram",
      "label": "Singleton / RAM",
      "type": "impl",
      "projects": [
        "agent"
      ],
      "metadata": {
        "description": "Pattern singleton giữ toàn bộ state trong RAM. Cực nhanh nhưng mất khi process tắt",
        "storage": "ram",
        "pros": [
          "Tốc độ cực nhanh",
          "Zero I/O overhead",
          "Đơn giản implement"
        ],
        "cons": [
          "Mất dữ liệu khi restart",
          "Bị giới hạn bởi RAM"
        ]
      }
    },
    {
